+static bool IsInEditableTextSelectionContext(const nsIFrame* aFrame) {
+  for (const nsIFrame* frame = aFrame; frame; frame = frame->GetParent()) {
+    if (frame->IsTextInputFrame() || frame->ContentIsEditable()) {
+      return true;
+    }
+    if (frame->Style()->GetPseudoType() ==
+        PseudoStyleType::MozTextControlEditingRoot) {
+      return true;
+    }
+  }
+  return false;
+}
+
